# EsportsForge Environment Configuration
# Copy to .env and fill in real values

# App
ENVIRONMENT=development
DEBUG=true
LOG_LEVEL=INFO

# Database
DATABASE_URL=sqlite+aiosqlite:///./esportsforge.db
REDIS_URL=

# Auth
SECRET_KEY=change-me-in-production
NEXTAUTH_SECRET=change-me-in-production
NEXTAUTH_URL=http://localhost:3000

# AI
ANTHROPIC_API_KEY=
CLAUDE_MODEL=claude-sonnet-4-20250514

# Stripe (optional)
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_VOICEFORGE_ENABLED=true
NEXT_PUBLIC_VISIONAUDIOFORGE_ENABLED=true
VISIONAUDIOFORGE_REQUIRE_OFFLINE_MODE=true
