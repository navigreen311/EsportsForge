# EsportsForge Environment Variables
# Copy to .env and fill in real values

# Database
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/esportsforge
REDIS_URL=redis://localhost:6379/0

# Auth
SECRET_KEY=YOUR_SECRET_KEY_HERE
NEXTAUTH_SECRET=YOUR_NEXTAUTH_SECRET_HERE
NEXTAUTH_URL=http://localhost:3000

# AI
ANTHROPIC_API_KEY=YOUR_ANTHROPIC_API_KEY_HERE
CLAUDE_MODEL=claude-sonnet-4-20250514

# App
ENVIRONMENT=development
DEBUG=true
NEXT_PUBLIC_API_URL=http://localhost:8000

# VoiceForge Integration
NEXT_PUBLIC_VOICEFORGE_ENABLED=true

# VisionAudioForge Integration
NEXT_PUBLIC_VISIONAUDIOFORGE_ENABLED=true
VISIONAUDIOFORGE_REQUIRE_OFFLINE_MODE=true
